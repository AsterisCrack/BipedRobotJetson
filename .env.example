# Copy this file to .env and uncomment/edit the lines you need.
# .env takes highest priority over config/hardware.yaml.
#
# IMPORTANT: Do not add inline comments (KEY=value  # comment).
# pydantic-settings includes everything after = as the value.
# Put comments on their own lines (above the KEY=value line).

# --- Hardware paths ---

# hardware UART on Jetson 40-pin header (default)
# UART_PORT=/dev/ttyTHS1

# USB-to-SCS adapter
# UART_PORT=/dev/ttyUSB0

# 40-pin header I2C on Jetson Orin Nano (default)
# I2C_BUS=7

# --- Bus manager tuning ---

# Apply SCHED_FIFO to the servo bus thread.
# Eliminates 1-3 ms P99 jitter from OS preemption.
# Requires: sudo setcap cap_sys_nice+eip $(readlink -f venv/bin/python3)
# (or run the server as root — silently ignored if not permitted)
# BIPED_RT_SCHEDULING=1

# Position-only SYNC_READ (2 bytes/servo instead of 8 bytes).
# Saves ~720 µs of UART time per cycle.
# Side effect: speed, load, voltage, temperature read as 0 in telemetry panel.
# BIPED_FAST_MODE=1

# --- Debug ---

# Enable DEBUG-level logging for kinematics/ and robot/ modules.
# BIPED_DEBUG=1
